index 7134028..b74431e 100644
--- a/lib/netdb/std.go
+++ b/lib/netdb/std.go
@@ -43,6 +43,12 @@ type StdNetDB struct {
 
 	PeerTracker *PeerTracker // tracks connection success/failure for peers
 
+	// ConnectedPeers optionally reports the peers a transport session exists
+	// with right now. When set, SelectPeers puts one of them first so the
+	// tunnel's gateway is a router we can already reach. Set by the router
+	// from its transport muxer; nil is fine and restores the old behaviour.
+	ConnectedPeers func() []common.Hash
+
