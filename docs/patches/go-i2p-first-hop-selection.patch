diff --git a/lib/transport/multi.go b/lib/transport/multi.go
index b91c69b..4403b7e 100644
--- a/lib/transport/multi.go
+++ b/lib/transport/multi.go
@@ -10,6 +10,7 @@ import (
 	"sync/atomic"
 	"time"
 
+	"github.com/go-i2p/common/data"
 	"github.com/go-i2p/common/router_info"
 	"github.com/go-i2p/logger"
 	"github.com/samber/oops"
@@ -840,3 +841,36 @@ func (tc *trackedConn) Close() error {
 	}
 	return tc.Conn.Close()
 }
+
+// connectedPeersReporter is implemented by transports that can enumerate the
+// peers they currently hold a session with.
+type connectedPeersReporter interface {
+	ConnectedPeers() []data.Hash
+}
+
+// ConnectedPeers returns the router hashes reachable right now over any
+// transport, deduplicated.
+//
+// Tunnel peer selection uses this to choose a first hop we already have a
+// session with. Selecting purely on netdb RouterInfo means the build request
+// only discovers an unreachable gateway when it times out, and each such miss
+// costs a full build attempt plus a peer marked failed. i2pd avoids this by
+// drawing the first hop from its transport peer set (TunnelPool.cpp:598-620).
+func (tmux *TransportMuxer) ConnectedPeers() []data.Hash {
+	seen := make(map[data.Hash]struct{})
+	var peers []data.Hash
+	for _, t := range tmux.trans {
+		reporter, ok := t.(connectedPeersReporter)
+		if !ok {
+			continue
+		}
+		for _, hash := range reporter.ConnectedPeers() {
+			if _, dup := seen[hash]; dup {
+				continue
+			}
+			seen[hash] = struct{}{}
+			peers = append(peers, hash)
+		}
+	}
+	return peers
+}
diff --git a/lib/transport/ntcp2/transport.go b/lib/transport/ntcp2/transport.go
index 887b1b6..0f31f94 100644
--- a/lib/transport/ntcp2/transport.go
+++ b/lib/transport/ntcp2/transport.go
@@ -1568,3 +1568,18 @@ func (t *NTCP2Transport) handleCloseCompletion(listenerErr error) error {
 func (t *NTCP2Transport) Name() string {
 	return "NTCP2"
 }
+
+// ConnectedPeers returns the router hashes this transport currently holds a
+// session for. Used by tunnel peer selection to prefer a first hop we can
+// already reach, instead of discovering unreachability only after a build
+// request times out.
+func (t *NTCP2Transport) ConnectedPeers() []data.Hash {
+	var peers []data.Hash
+	t.sessions.Range(func(key, _ interface{}) bool {
+		if hash, ok := key.(data.Hash); ok {
+			peers = append(peers, hash)
+		}
+		return true
+	})
+	return peers
+}
