diff --git a/lib/netdb/std_peer_selection.go b/lib/netdb/std_peer_selection.go
index ac6201b..69675d2 100644
--- a/lib/netdb/std_peer_selection.go
+++ b/lib/netdb/std_peer_selection.go
@@ -341,6 +341,7 @@ func (db *StdNetDB) SelectPeers(count int, exclude []common.Hash) ([]router_info
 	}
 
 	selected := db.selectRandomPeers(available, count)
+	selected = db.preferConnectedFirstHop(selected, available)
 	log.WithFields(logger.Fields{
 		"at":             "StdNetDB.SelectPeers",
 		"reason":         "selection_complete",
@@ -349,6 +350,93 @@ func (db *StdNetDB) SelectPeers(count int, exclude []common.Hash) ([]router_info
 	return selected, nil
 }
 
+// preferConnectedFirstHop makes selected[0] a router we already hold a
+// transport session with, when one is available.
+//
+// The gateway is the only hop we dial ourselves; the rest are reached through
+// the tunnel. Choosing it purely from netdb means an unreachable gateway is
+// only discovered when the build request fails, and every miss costs a full
+// build attempt plus peers marked failed — which on a network where many
+// advertised routers are undialable can stall tunnel building indefinitely.
+//
+// i2pd takes the first hop from its transport peer set for the same reason
+// (TunnelPool.cpp:598-620, "Can't select first hop for a tunnel. Trying
+// already connected"). Only the first hop is touched here, so hop selection
+// stays otherwise random and the anonymity properties of the remaining hops
+// are unchanged.
+func (db *StdNetDB) preferConnectedFirstHop(selected, available []router_info.RouterInfo) []router_info.RouterInfo {
+	if db.ConnectedPeers == nil || len(selected) == 0 {
+		return selected
+	}
+	connected := db.ConnectedPeers()
+	if len(connected) == 0 {
+		return selected
+	}
+	connectedSet := make(map[common.Hash]struct{}, len(connected))
+	for _, hash := range connected {
+		connectedSet[hash] = struct{}{}
+	}
+
+	isConnected := func(ri router_info.RouterInfo) bool {
+		hash, err := ri.IdentHash()
+		if err != nil {
+			return false
+		}
+		_, ok := connectedSet[hash]
+		return ok
+	}
+
+	// Already good, or one of the other hops qualifies — swap it to the front.
+	for i, ri := range selected {
+		if !isConnected(ri) {
+			continue
+		}
+		if i > 0 {
+			selected[0], selected[i] = selected[i], selected[0]
+			log.WithFields(logger.Fields{
+				"at":     "StdNetDB.preferConnectedFirstHop",
+				"reason": "promoted an already-connected hop to gateway",
+				"from":   i,
+			}).Debug("first hop reordered")
+		}
+		return selected
+	}
+
+	// None of the picked hops is connected: substitute a connected peer that
+	// passed the same filtering, as long as it is not already in the path.
+	inPath := make(map[common.Hash]struct{}, len(selected))
+	for _, ri := range selected {
+		if hash, err := ri.IdentHash(); err == nil {
+			inPath[hash] = struct{}{}
+		}
+	}
+	for _, candidate := range available {
+		hash, err := candidate.IdentHash()
+		if err != nil {
+			continue
+		}
+		if _, dup := inPath[hash]; dup {
+			continue
+		}
+		if _, ok := connectedSet[hash]; !ok {
+			continue
+		}
+		log.WithFields(logger.Fields{
+			"at":     "StdNetDB.preferConnectedFirstHop",
+			"reason": "no selected hop was connected, substituted a connected peer as gateway",
+		}).Debug("first hop substituted")
+		selected[0] = candidate
+		return selected
+	}
+
+	log.WithFields(logger.Fields{
+		"at":              "StdNetDB.preferConnectedFirstHop",
+		"reason":          "no connected peer passed filtering, leaving selection as is",
+		"connected_peers": len(connected),
+	}).Debug("first hop unchanged")
+	return selected
+}
