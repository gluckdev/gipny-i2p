{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "gipny-i2p",
  "version": "0.3.4",
  "identifier": "app.gipny.i2p",
  "build": {
    "frontendDist": "../ui/dist"
  },
  "app": {
    "windows": [
      {
        "title": "gipny (i2p)",
        "width": 1100,
        "height": 720,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "decorations": true,
        "transparent": false,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; script-src 'self'; img-src 'self' data: blob:; connect-src 'self' ipc: http://ipc.localhost; object-src 'none'; base-uri 'none'; form-action 'none'; frame-src 'none'; frame-ancestors 'none'; media-src 'self' blob:; worker-src 'self'",
      "capabilities": ["default"]
    }
  },
  "bundle": {
    "active": true,
    "targets": ["appimage", "nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.png",
      "icons/icon.ico"
    ],
    "resources": ["resources/gipny-i2p-router*"],
    "copyright": "",
    "category": "SocialNetworking",
    "shortDescription": "Private messenger",
    "longDescription": "Anonymous messenger over i2p with E2E encryption."
  }
}